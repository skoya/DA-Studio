---
import ShellLayout from '@/layouts/ShellLayout.astro';
---

<ShellLayout title="Component Labs | Digital Asset Studio">
  <section class="section">
    <div class="grid three-col">
      <div class="card">
        <span class="pill">Badge</span>
        <h3>Trust metadata</h3>
        <p>Used across source cards and market packs.</p>
      </div>
      <div class="card">
        <span class="pill">Context bar</span>
        <h3>Global selectors</h3>
        <p>Lens, depth, market, client segment, and network persist locally.</p>
      </div>
      <div class="card">
        <span class="pill">SVG exports</span>
        <h3>Analysis visuals</h3>
        <p>Charts export as SVG so presentations stay crisp and inspectable.</p>
      </div>
    </div>
  </section>
</ShellLayout>
